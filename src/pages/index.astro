---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Town Home Schoolhouse | Faith-Based Homeschool Enrichment">
	<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
		<div class="absolute inset-0">
			<img 
				src="/schoolhouse-site/images/schoolhouse-exterior.png" 
				alt="Town Home Schoolhouse" 
				class="w-full h-full object-cover"
			/>
			<div class="absolute inset-0 bg-rustic-900/70"></div>
		</div>
		<div class="relative z-10 max-w-4xl mx-auto text-center px-6 py-32">
			<h1 class="text-6xl md:text-8xl font-serif font-bold text-rustic-100 mb-4 tracking-wide">
				Town Home
			</h1>
			<h2 class="text-4xl md:text-5xl font-serif text-rustic-300 mb-6">
				Schoolhouse
			</h2>
			<p class="text-xl text-rustic-200 max-w-2xl mx-auto mt-8 leading-relaxed">
				Building Faith, Knowledge & Character in a high-energy, interactive environment
			</p>
			<div class="flex gap-4 justify-center mt-12">
				<a href="#programs" class="bg-rustic-500 text-white px-10 py-4 rounded font-semibold hover:bg-rustic-400 transition text-lg">
					View Programs
				</a>
				<a href="#contact" class="bg-transparent border-2 border-rustic-300 text-rustic-100 px-10 py-4 rounded font-semibold hover:bg-rustic-800/50 transition text-lg">
					Contact Us
				</a>
			</div>
		</div>
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-rustic-300 animate-bounce">
			<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
			</svg>
		</div>
	</section>
	<section class="py-24 px-6 bg-rustic-50">
		<div class="max-w-4xl mx-auto text-center">
			<div class="bg-rustic-100 p-12 rounded-lg shadow-lg border-2 border-rustic-200">
				<h2 class="text-3xl font-serif font-bold text-rustic-800 mb-8">Mission & Vision</h2>
				<p class="text-rustic-700 text-lg mb-6 leading-relaxed">
					To enrich the homeschool journey by building faith, knowledge, and character in a 
					high-energy, interactive environment that fosters genuine camaraderie and a lifelong love of discovery. 
					Rooted in the counsel of Paul in Philippians 4:8, our goal at Town Home Schoolhouse is to 
					cultivate an edifying educational atmosphere focused on things that are pure, lovely, virtuous, and praiseworthy.
				</p>
				<p class="text-rustic-700 text-lg mb-8 leading-relaxed">
					We strive to provide homeschool families with a socially interactive and sensory-engaging space 
					that strengthens a child's confidence, fosters critical thinking, and supports their holistic growth.
				</p>
				<p class="text-rustic-600 italic border-l-4 border-rustic-500 pl-6 py-4 bg-rustic-50">
					"...whatever things are true, whatever things are noble, whatever things are just, 
					whatever things are pure, whatever things are lovely, whatever things are of good report..." 
					<strong>— Philippians 4:8</strong>
				</p>
			</div>
		</div>
	</section>
	<section id="about" class="py-24 px-6 bg-rustic-200">
		<div class="max-w-6xl mx-auto">
			<div class="grid md:grid-cols-2 gap-16 items-center">
				<div class="relative">
					<img 
						src="/schoolhouse-site/dist/images/title.png"
						alt="Title" 
						class="rounded-lg shadow-2xl w-full"
					/>
					<div class="absolute -bottom-4 -right-4 w-full h-full border-4 border-rustic-600 rounded-lg -z-10"></div>
				</div>
				<div>
					<h2 class="text-3xl font-serif font-bold text-rustic-900 mb-6">The Advantage of Our Small Classroom Setting</h2>
					<p class="text-rustic-700 mb-6 text-lg">
						At Town Home Schoolhouse, we believe face-to-face connections are a treasure. 
						By intentionally capping our class, we offer a personalized, relational approach 
						to education that simply isn't possible in larger institutional settings.
					</p>
					<ul class="space-y-4">
						<li class="flex items-start bg-rustic-50 p-4 rounded">
							<span class="text-rustic-600 mr-3 text-xl">✦</span>
							<span><strong class="text-rustic-800">Deepening Community & Friendships:</strong> Small class sizes ensure that every student is seen, known, and valued. This structure naturally forges strong friendships among peers and builds a tight-knit community between families.</span>
						</li>
						<li class="flex items-start bg-rustic-50 p-4 rounded">
							<span class="text-rustic-600 mr-3 text-xl">✦</span>
							<span><strong class="text-rustic-800">Addressing the Whole Person:</strong> In our Christian environment, we view each child as an individual created by God for His good purposes. A smaller ratio allows our teachers to go beyond basic academics to gently address the "attitudes of the heart."</span>
						</li>
						<li class="flex items-start bg-rustic-50 p-4 rounded">
							<span class="text-rustic-600 mr-3 text-xl">✦</span>
							<span><strong class="text-rustic-800">Character Development:</strong> Character is addressed daily—not just for the sake of learning kindness, goodness, and patience, but because it honors God. We teach children to treat one another with the respect and love they desire for themselves.</span>
						</li>
						<li class="flex items-start bg-rustic-50 p-4 rounded">
							<span class="text-rustic-600 mr-3 text-xl">✦</span>
							<span><strong class="text-rustic-800">Spiritual & Academic Thriving:</strong> We believe children thrive in their education when they are simultaneously growing in their understanding of Jesus Christ. Our intimate classroom setting gives teachers the freedom to guide students in walking in His ways, making whole-person growth our greatest passion.</span>
						</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- Programs Overview -->
	<section id="programs" class="py-24 px-6 bg-rustic-100">
		<div class="max-w-5xl mx-auto">
			<h2 class="text-4xl font-serif font-bold text-center text-rustic-900 mb-4">Our Programs</h2>
			<p class="text-center text-rustic-600 mb-4 text-lg">
				Once-a-week classes for ages 6–18
			</p>
			<p class="text-center text-rustic-700 mb-16">
				Hands-on learning through movement, teamwork, and creative application.
			</p>
			
			<!-- Younger Students - Ages 6-10 -->
			<div class="mb-16">
				<h3 class="text-2xl font-bold text-rustic-800 mb-8 text-center bg-rustic-200 inline-block px-8 py-2 rounded-full mx-auto">
					Ages 6–10 | Tuesdays
				</h3>
				<div class="space-y-6">
					<!-- PPC Phonics -->
					<div class="bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition">
						<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
							<div>
								<h4 class="text-xl font-bold text-rustic-800 flex items-center gap-2">
									PPC - Phonics, Comprehension & Creativity
								</h4>
								<p class="text-rustic-500 text-sm mt-1">Tuesdays 1:00 PM – 2:00 PM</p>
							</div>
							<span class="bg-rustic-500 text-white px-4 py-1 rounded-full text-sm font-semibold mt-2 md:mt-0">$30/month</span>
						</div>
						<p class="text-rustic-600 mb-4">Strengthening reading skills through multi-sensory approach—active play, storytelling, and hands-on crafts.</p>
						<div class="flex flex-wrap gap-2">
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Phonics Rules</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Reading Comprehension</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Storytelling</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Creative Crafts</span>
						</div>
					</div>
					
					<!-- Math Madness 6-10 -->
					<div class="bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition">
						<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
							<div>
								<h4 class="text-xl font-bold text-rustic-800 flex items-center gap-2">
									Math Madness
								</h4>
								<p class="text-rustic-500 text-sm mt-1">Tuesdays 2:00 PM – 3:00 PM</p>
							</div>
							<span class="bg-rustic-500 text-white px-4 py-1 rounded-full text-sm font-semibold mt-2 md:mt-0">$30/month</span>
						</div>
						<p class="text-rustic-600 mb-4">Energetic, multi-sensory math—movement, teamwork, and creative play to build foundational skills.</p>
						<div class="flex flex-wrap gap-2">
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Real-World Math</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Math Relays</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Team Challenges</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Mnemonic Devices</span>
						</div>
					</div>
					
					<!-- Home Ec & Ag 6-10 -->
					<div class="bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition">
						<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
							<div>
								<h4 class="text-xl font-bold text-rustic-800 flex items-center gap-2">
									Home Economics & Agriculture
								</h4>
								<p class="text-rustic-500 text-sm mt-1">Tuesdays 3:00 PM – 5:00 PM</p>
							</div>
							<span class="bg-rustic-500 text-white px-4 py-1 rounded-full text-sm font-semibold mt-2 md:mt-0">$60/month</span>
						</div>
						<p class="text-rustic-600 mb-4">Mastering essential life skills through practical, hands-on application—outdoors and indoors.</p>
						<div class="flex flex-wrap gap-2">
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Cooking & Preservation</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Sewing & Textiles</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Gardening</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Basic Woodworking</span>
						</div>
					</div>
				</div>
			</div>
			
			<!-- Older Students - Ages 10-18 -->
			<div class="mb-16">
				<h3 class="text-2xl font-bold text-rustic-800 mb-8 text-center bg-rustic-300 inline-block px-8 py-2 rounded-full mx-auto">
					Ages 10–18 | Thursdays
				</h3>
				<div class="space-y-6">
					<!-- Writing, Debate & Storytelling -->
					<div class="bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition">
						<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
							<div>
								<h4 class="text-xl font-bold text-rustic-800 flex items-center gap-2">
									Writing, Debate & Storytelling
								</h4>
								<p class="text-rustic-500 text-sm mt-1">Thursdays 12:45 PM – 2:30 PM</p>
							</div>
							<span class="bg-rustic-500 text-white px-4 py-1 rounded-full text-sm font-semibold mt-2 md:mt-0">$50/month</span>
						</div>
						<p class="text-rustic-600 mb-4">Comprehensive language arts—IEW-style writing, structured debate, and compelling storytelling.</p>
						<div class="flex flex-wrap gap-2">
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Writing Foundations</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Stylistic Techniques</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Structured Debate</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Public Speaking</span>
						</div>
					</div>
					
					<!-- Math Madness 10-18 -->
					<div class="bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition">
						<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
							<div>
								<h4 class="text-xl font-bold text-rustic-800 flex items-center gap-2">
									 Math Madness
								</h4>
								<p class="text-rustic-500 text-sm mt-1">Thursdays 2:30 PM – 3:15 PM</p>
							</div>
							<span class="bg-rustic-500 text-white px-4 py-1 rounded-full text-sm font-semibold mt-2 md:mt-0">$25/month</span>
						</div>
						<p class="text-rustic-600 mb-4">Dynamic, interactive math—movement, strategic teamwork, and hands-on application.</p>
						<div class="flex flex-wrap gap-2">
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Financial Literacy</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Budget & Interest</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Logic Scavenger Hunts</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Math Tournaments</span>
						</div>
					</div>
					
					<!-- U.S. Geography -->
					<div class="bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition">
						<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
							<div>
								<h4 class="text-xl font-bold text-rustic-800 flex items-center gap-2">
									U.S. Geography: Fun & Games
								</h4>
								<p class="text-rustic-500 text-sm mt-1">Thursdays 3:15 PM – 4:00 PM</p>
							</div>
							<span class="bg-rustic-500 text-white px-4 py-1 rounded-full text-sm font-semibold mt-2 md:mt-0">$25/month</span>
						</div>
						<p class="text-rustic-600 mb-4">Interactive geography—mapping, state quizzes, and competitive gameplay across the 50 states.</p>
						<div class="flex flex-wrap gap-2">
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">States & Capitals</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">History & Culture</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Interactive Mapping</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">State Notebooks</span>
						</div>
					</div>
					
					<!-- Home Ec & Ag 10-18 -->
					<div class="bg-white p-8 rounded-lg shadow-md hover:shadow-xl transition">
						<div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
							<div>
								<h4 class="text-xl font-bold text-rustic-800 flex items-center gap-2">
									Home Economics & Agriculture
								</h4>
								<p class="text-rustic-500 text-sm mt-1">Thursdays 4:00 PM – 6:00 PM</p>
							</div>
							<span class="bg-rustic-500 text-white px-4 py-1 rounded-full text-sm font-semibold mt-2 md:mt-0">$60/month</span>
						</div>
						<p class="text-rustic-600 mb-4">Mastering essential life skills through practical application and independent problem-solving.</p>
						<div class="flex flex-wrap gap-2">
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Culinary Science</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Machine & Hand Sewing</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Carpentry Projects</span>
							<span class="bg-rustic-100 text-rustic-700 px-3 py-1 rounded-full text-xs">Financial Literacy</span>
						</div>
					</div>
				</div>
			</div>
			
			<!-- Our Approach - Rustic Box -->
			<div class="bg-rustic-800 text-rustic-100 p-12 rounded-lg">
				<h3 class="text-2xl font-bold text-rustic-200 mb-8 text-center">Our Approach</h3>
				<p class="text-rustic-300 text-center mb-8 text-lg">
					Town Home Schoolhouse is designed to support and strengthen the homeschooling family by offering 
					specialized, once-a-week extracurricular enhancements rather than a comprehensive core curriculum. 
					Serving students from ages 6 through 18, our classes bring learning to life through movement, teamwork, and hands-on application.
				</p>
				<div class="grid md:grid-cols-3 gap-8">
					<div class="text-center bg-rustic-700 p-6 rounded">
						<h4 class="font-bold text-rustic-200 mb-2">Multi-Sensory & Active</h4>
						<p class="text-rustic-400">We step away from the traditional desk environment. Students participate in mock stores, whiteboard relays, seed-to-table gardening, and tactical crafts to make learning memorable.</p>
					</div>
					<div class="text-center bg-rustic-700 p-6 rounded">
						<h4 class="font-bold text-rustic-200 mb-2">Structured for Connection</h4>
						<p class="text-rustic-400">To ensure a smooth transition between sessions and provide valuable outdoor socialization, each class concludes with a 10-minute recess and snack break.</p>
					</div>
					<div class="text-center bg-rustic-700 p-6 rounded">
						<h4 class="font-bold text-rustic-200 mb-2">Family-Focused</h4>
						<p class="text-rustic-400">We are committed to supporting entire families in their homeschool journey. We proudly offer a sibling discount—the first child's tuition is full price, and each additional sibling receives a 10% discount.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Enrollment -->
	<section class="py-16 px-6 bg-rustic-700">
		<div class="max-w-4xl mx-auto text-center">
			<h2 class="text-3xl font-serif font-bold text-rustic-100 mb-6">Enrollment</h2>
			<p class="text-rustic-200 mb-4 text-lg">
				Classes meet once a week during Fall and Spring semesters.
			</p>
			<p class="text-rustic-100 text-xl">
				<strong>First child:</strong> Full tuition &nbsp;•&nbsp; 
				<strong>Each additional sibling:</strong> 10% discount
			</p>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="py-24 px-6 bg-rustic-100">
		<div class="max-w-3xl mx-auto">
			<h2 class="text-3xl font-serif font-bold text-center text-rustic-900 mb-4">Contact Us</h2>
			<p class="text-center text-rustic-600 mb-10">Ready to join our homeschool community?</p>
			
			<form action="https://formspree.io/f/mkoklobn" method="POST" class="space-y-6" id="contact-form">
				<div>
					<label for="name" class="block text-rustic-800 font-medium mb-2">Your Name</label>
					<input 
						type="text" 
						id="name" 
						name="name" 
						required
						class="w-full px-4 py-3 border-2 border-rustic-300 rounded focus:ring-2 focus:ring-rustic-500 focus:border-rustic-500 outline-none bg-white"
						placeholder="Your name"
					>
				</div>
				
				<div>
					<label for="email" class="block text-rustic-800 font-medium mb-2">Email Address</label>
					<input 
						type="email" 
						id="email" 
						name="email" 
						required
						class="w-full px-4 py-3 border-2 border-rustic-300 rounded focus:ring-2 focus:ring-rustic-500 focus:border-rustic-500 outline-none bg-white"
						placeholder="your@email.com"
					>
				</div>
				
				<div>
					<label for="subject" class="block text-rustic-800 font-medium mb-2">Subject</label>
					<select 
						id="subject" 
						name="subject"
						class="w-full px-4 py-3 border-2 border-rustic-300 rounded focus:ring-2 focus:ring-rustic-500 focus:border-rustic-500 outline-none bg-white"
					>
						<option value="">Select a topic...</option>
						<option value="enrollment">Enrollment Questions</option>
						<option value="programs">Program Information</option>
						<option value="tour">Schedule a Tour</option>
						<option value="other">Other</option>
					</select>
				</div>
				
				<div>
					<label for="message" class="block text-rustic-800 font-medium mb-2">Message</label>
					<textarea 
						id="message" 
						name="message" 
						rows="5"
						required
						class="w-full px-4 py-3 border-2 border-rustic-300 rounded focus:ring-2 focus:ring-rustic-500 focus:border-rustic-500 outline-none bg-white"
						placeholder="Tell us about your family and homeschool needs..."
					></textarea>
				</div>
				
				<button 
					type="submit" 
					class="w-full bg-rustic-600 text-white py-4 px-6 rounded font-semibold hover:bg-rustic-500 transition text-lg"
				>
					Send Message
				</button>
			</form>
		</div>
	</section>

	<!-- Footer -->
	<footer class="bg-rustic-900 text-rustic-300 py-12 px-6">
		<div class="max-w-4xl mx-auto text-center">
			<p class="text-2xl font-serif text-rustic-200 mb-4">Town Home Schoolhouse</p>
			<p class="text-rustic-400 mb-2">Carthage, Harrison County, Texas</p>
			<p class="text-rustic-500 text-sm mt-6">&copy; 2026 Town Home Schoolhouse. All rights reserved.</p>
		</div>
	</footer>

	<script>
		const form = document.getElementById('contact-form');
		if (form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const formData = new FormData(form);
				const submitBtn = form.querySelector('button[type="submit"]');
				const originalText = submitBtn.textContent;
				submitBtn.textContent = 'Sending...';
				submitBtn.disabled = true;

				try {
					const response = await fetch('https://formspree.io/f/mkoklobn', {
						method: 'POST',
						body: formData,
						headers: {
							'Accept': 'application/json'
						}
					});
					if (response.ok) {
						alert('Thank you! Your message has been sent successfully.');
						form.reset();
					} else {
						alert('Something went wrong. Please try again.');
					}
				} catch (error) {
					alert('Error submitting form. Please try again.');
				} finally {
					submitBtn.textContent = originalText;
					submitBtn.disabled = false;
				}
			});
		}
	</script>
</Layout>