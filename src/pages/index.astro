	<!-- Contact Section -->
	<section id="contact" class="py-24 px-6 bg-rustic-100">
		<div class="max-w-3xl mx-auto">
			<h2 class="text-3xl font-serif font-bold text-center text-rustic-900 mb-4">Contact Us</h2>
			<p class="text-center text-rustic-600 mb-10">Ready to join our homeschool community?</p>
			
			<form action="https://formspree.io/f/mkoklobn" method="POST" class="space-y-6" id="contact-form">
				<div>
					<label for="name" class="block text-rustic-800 font-medium mb-2">Your Name</label>
					<input 
						type="text" 
						id="name" 
						name="name" 
						required
						class="w-full px-4 py-3 border-2 border-rustic-300 rounded focus:ring-2 focus:ring-rustic-500 focus:border-rustic-500 outline-none bg-white"
						placeholder="Your name"
					>
				</div>
				
				<div>
					<label for="email" class="block text-rustic-800 font-medium mb-2">Email Address</label>
					<input 
						type="email" 
						id="email" 
						name="email" 
						required
						class="w-full px-4 py-3 border-2 border-rustic-300 rounded focus:ring-2 focus:ring-rustic-500 focus:border-rustic-500 outline-none bg-white"
						placeholder="your@email.com"
					>
				</div>
				
				<div>
					<label for="subject" class="block text-rustic-800 font-medium mb-2">Subject</label>
					<select 
						id="subject" 
						name="subject"
						class="w-full px-4 py-3 border-2 border-rustic-300 rounded focus:ring-2 focus:ring-rustic-500 focus:border-rustic-500 outline-none bg-white"
					>
						<option value="">Select a topic...</option>
						<option value="enrollment">Enrollment Questions</option>
						<option value="programs">Program Information</option>
						<option value="tour">Schedule a Tour</option>
						<option value="other">Other</option>
					</select>
				</div>
				
				<div>
					<label for="message" class="block text-rustic-800 font-medium mb-2">Message</label>
					<textarea 
						id="message" 
						name="message" 
						rows="5"
						required
						class="w-full px-4 py-3 border-2 border-rustic-300 rounded focus:ring-2 focus:ring-rustic-500 focus:border-rustic-500 outline-none bg-white"
						placeholder="Tell us about your family and homeschool needs..."
					></textarea>
				</div>
				
				<button 
					type="submit" 
					class="w-full bg-rustic-600 text-white py-4 px-6 rounded font-semibold hover:bg-rustic-500 transition text-lg"
				>
					Send Message
				</button>
			</form>
		</div>
