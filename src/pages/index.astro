---
import Layout from '../layouts/Layout.astro';
---

<Layout title="One Room Schoolhouse | Piney Woods">
	<!-- Hero Section -->
	<section class="relative bg-gradient-to-b from-green-900 to-green-950 py-24 px-6">
		<div class="max-w-4xl mx-auto text-center">
			<h1 class="text-5xl md:text-6xl font-serif font-bold text-amber-50 mb-4">
				One Room Schoolhouse
			</h1>
			<p class="text-2xl text-amber-200 italic mb-2">A Vintage Education</p>
			<p class="text-xl text-green-100 max-w-2xl mx-auto mt-8">
				A tried and true approach to a rich and meaningful education in a one-room setting.
			</p>
			<div class="flex gap-4 justify-center mt-10">
				<a href="#schedule" class="bg-amber-600 text-white px-8 py-3 rounded font-semibold hover:bg-amber-700 transition">
					View Schedule
				</a>
				<a href="#contact" class="bg-transparent border-2 border-amber-200 text-amber-200 px-8 py-3 rounded font-semibold hover:bg-amber-900/30 transition">
					Contact Us
				</a>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<section id="about" class="py-16 px-6 bg-stone-50">
		<div class="max-w-4xl mx-auto">
			<h2 class="text-3xl font-serif font-bold text-center text-green-900 mb-8">The Blessing of a One Room Setting</h2>
			<div class="prose mx-auto text-green-800 text-center">
				<p class="mb-6">
					The small classroom sizes allow every student to get to know each other which forges 
					friendships and builds community between families at a time in the world where face to 
					face connections are a treasure.
				</p>
				<p>
					The Christian environment means that each child is valued as an individual created by God 
					for His good purposes and that children will be taught to treat one another how they 
					want to be treated inside and outside of class.
				</p>
			</div>
		</div>
	</section>

	<!-- Educator Section -->
	<section class="py-16 px-6 bg-green-50">
		<div class="max-w-4xl mx-auto">
			<h2 class="text-3xl font-serif font-bold text-center text-green-900 mb-8">Your Christian Educator</h2>
			<div class="bg-white p-8 rounded-lg shadow-md text-center">
				<p class="text-lg text-green-800 italic mb-4">
					Homesteader, patriot and homeschool family
				</p>
				<p class="text-green-700">
					After many years of teaching experience in classrooms and homeschool settings, 
					we opened a one room schoolhouse so that other children could benefit from a 
					multi-age small classroom setting. Our desire is to be a resource to other 
					homeschool and public school families, offering guidance to parents as well as 
					children so that the whole family can benefit from a tried and true educational approach.
				</p>
			</div>
		</div>
	</section>

	<!-- Schedule/Classes Section -->
	<section id="schedule" class="py-16 px-6 bg-white">
		<div class="max-w-5xl mx-auto">
			<h2 class="text-3xl font-serif font-bold text-center text-green-900 mb-4">Schedule</h2>
			<p class="text-center text-green-700 mb-12">Classes offered on Tuesdays and Thursdays during Fall and Spring semesters</p>
			
			<div class="grid md:grid-cols-2 gap-6">
				<!-- Class Card 1 -->
				<div class="bg-stone-50 p-6 rounded-lg border-l-4 border-green-700">
					<h3 class="text-xl font-bold text-green-900 mb-2">Christian Worldview History</h3>
					<p class="text-green-700 text-sm mb-3">Ages 5-17 | 4-year rotation</p>
					<p class="text-green-600">Covers ancient, medieval, renaissance, and modern world history including church history throughout each of the ages.</p>
				</div>
				
				<!-- Class Card 2 -->
				<div class="bg-stone-50 p-6 rounded-lg border-l-4 border-green-700">
					<h3 class="text-xl font-bold text-green-900 mb-2">Creationism Science</h3>
					<p class="text-green-700 text-sm mb-3">Ages 5-17 | 4-year rotation</p>
					<p class="text-green-600">Covers earth science, biology, chemistry and physics including biblical references to put science into the proper perspective in light of God's creation.</p>
				</div>
				
				<!-- Class Card 3 -->
				<div class="bg-stone-50 p-6 rounded-lg border-l-4 border-green-700">
					<h3 class="text-xl font-bold text-green-900 mb-2">Indoor Life Skills</h3>
					<p class="text-green-700 text-sm mb-3">Ages 5-17</p>
					<p class="text-green-600">Modern homesteading class covering budgeting, nutrition, cooking, baking, meal prepping, time management, basic sewing, and entrepreneurialism.</p>
				</div>
				
				<!-- Class Card 4 -->
				<div class="bg-stone-50 p-6 rounded-lg border-l-4 border-green-700">
					<h3 class="text-xl font-bold text-green-900 mb-2">Outdoor Life Skills</h3>
					<p class="text-green-700 text-sm mb-3">Ages 5-17</p>
					<p class="text-green-600">Tending to animals, gardening, wood working, fire making, basic survival skills and physical education.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Additional Programs -->
	<section class="py-16 px-6 bg-amber-50">
		<div class="max-w-4xl mx-auto">
			<h2 class="text-3xl font-serif font-bold text-center text-green-900 mb-8">Additional Programs</h2>
			<div class="grid md:grid-cols-2 gap-6">
				<div class="bg-white p-6 rounded-lg shadow-sm">
					<h3 class="text-lg font-bold text-green-800 mb-2">Early Readers Class</h3>
					<p class="text-green-600 text-sm">Ages 3.5-7</p>
					<p class="text-green-700 mt-2">Basic letter recognition, sounds, blending and writing. Each class ends with story time.</p>
				</div>
				<div class="bg-white p-6 rounded-lg shadow-sm">
					<h3 class="text-lg font-bold text-green-800 mb-2">Mommy-and-Me Story Time</h3>
					<p class="text-green-600 text-sm">All ages</p>
					<p class="text-green-700 mt-2">Read a story together then hands-on time with farm animals. Babies under 1 attend free!</p>
				</div>
				<div class="bg-white p-6 rounded-lg shadow-sm">
					<h3 class="text-lg font-bold text-green-800 mb-2">Homeschool Prep for Moms</h3>
					<p class="text-green-600 text-sm">For new homeschool families</p>
					<p class="text-green-700 mt-2">Covers homeschool styles, curriculum, scheduling, teaching to your child's bent, and creating routines.</p>
				</div>
				<div class="bg-white p-6 rounded-lg shadow-sm">
					<h3 class="text-lg font-bold text-green-800 mb-2">Photography Sessions</h3>
					<p class="text-green-600 text-sm">Available</p>
					<p class="text-green-700 mt-2">Classic schoolhouse setting with antique props for first day, seasonal, sports or senior photos.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Enrollment Info -->
	<section class="py-16 px-6 bg-green-900 text-green-50">
		<div class="max-w-4xl mx-auto text-center">
			<h2 class="text-3xl font-serif font-bold mb-6">Enrollment & Course Fees</h2>
			<div class="grid md:grid-cols-3 gap-8 mb-10">
				<div>
					<p class="text-amber-300 text-sm uppercase tracking-wide mb-1">Enrollment Fee</p>
					<p class="text-3xl font-bold">$20</p>
					<p class="text-green-300 text-sm">per family (one-time)</p>
				</div>
				<div>
					<p class="text-amber-300 text-sm uppercase tracking-wide mb-1">Per Class</p>
					<p class="text-3xl font-bold">$28</p>
					<p class="text-green-300 text-sm">per month ($7 per class)</p>
				</div>
				<div>
					<p class="text-amber-300 text-sm uppercase tracking-wide mb-1">Multi-Class</p>
					<p class="text-3xl font-bold">$20</p>
					<p class="text-green-300 text-sm">per month when enrolled in multiple classes</p>
				</div>
			</div>
			<p class="text-green-200 italic">
				Classes are a flat rate per month even if students miss classes. 
				Limited make-up classes offered.
			</p>
		</div>
	</section>

	<!-- Contact Section -->
	<section id="contact" class="py-16 px-6 bg-stone-100">
		<div class="max-w-3xl mx-auto">
			<h2 class="text-3xl font-serif font-bold text-center text-green-900 mb-4">Contact Us</h2>
			<p class="text-center text-green-700 mb-8">Reach out to enroll or schedule a tour!</p>
			
			<form action="https://formspree.io/f/mkoklobn" method="POST" class="space-y-6" id="contact-form">
				<div>
					<label for="name" class="block text-green-800 font-medium mb-2">Your Name</label>
					<input 
						type="text" 
						id="name" 
						name="name" 
						required
						class="w-full px-4 py-3 border border-green-300 rounded focus:ring-2 focus:ring-green-600 focus:border-green-600 outline-none bg-white"
						placeholder="Your name"
					>
				</div>
				
				<div>
					<label for="email" class="block text-green-800 font-medium mb-2">Email Address</label>
					<input 
						type="email" 
						id="email" 
						name="email" 
						required
						class="w-full px-4 py-3 border border-green-300 rounded focus:ring-2 focus:ring-green-600 focus:border-green-600 outline-none bg-white"
						placeholder="your@email.com"
					>
				</div>
				
				<div>
					<label for="subject" class="block text-green-800 font-medium mb-2">Subject</label>
					<select 
						id="subject" 
						name="subject"
						class="w-full px-4 py-3 border border-green-300 rounded focus:ring-2 focus:ring-green-600 focus:border-green-600 outline-none bg-white"
					>
						<option value="">Select a topic...</option>
						<option value="enrollment">Enrollment Questions</option>
						<option value="tour">Schedule a Tour</option>
						<option value="classes">Class Information</option>
						<option value="other">Other</option>
					</select>
				</div>
				
				<div>
					<label for="message" class="block text-green-800 font-medium mb-2">Message</label>
					<textarea 
						id="message" 
						name="message" 
						rows="5"
						required
						class="w-full px-4 py-3 border border-green-300 rounded focus:ring-2 focus:ring-green-600 focus:border-green-600 outline-none bg-white"
						placeholder="Tell us about your family and homeschool needs..."
					></textarea>
				</div>
				
				<button 
					type="submit" 
					class="w-full bg-green-700 text-white py-3 px-6 rounded font-semibold hover:bg-green-800 transition"
				>
					Send Message
				</button>
			</form>
		</div>
	</section>

	<!-- Footer -->
	<footer class="bg-green-950 text-green-200 py-12 px-6">
		<div class="max-w-4xl mx-auto text-center">
			<p class="text-amber-200 mb-4">&copy; 2026 One Room Schoolhouse</p>
			<p class="text-sm text-green-400">
				Carthage, Harrison County, Texas
			</p>
		</div>
	</footer>

	<script>
		const form = document.getElementById('contact-form');
		if (form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				const formData = new FormData(form);
				const submitBtn = form.querySelector('button[type="submit"]');
				const originalText = submitBtn.textContent;
				submitBtn.textContent = 'Sending...';
				submitBtn.disabled = true;

				try {
					const response = await fetch('https://formspree.io/f/mkoklobn', {
						method: 'POST',
						body: formData,
						headers: {
							'Accept': 'application/json'
						}
					});
					if (response.ok) {
						alert('Thank you! Your message has been sent successfully.');
						form.reset();
					} else {
						alert('Something went wrong. Please try again.');
					}
				} catch (error) {
					alert('Error submitting form. Please try again.');
				} finally {
					submitBtn.textContent = originalText;
					submitBtn.disabled = false;
				}
			});
		}
	</script>
</Layout>